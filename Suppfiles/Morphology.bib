@article{rydingShapeshiftingRelativeWing2025,
  title = {Shape-shifting in Relative Wing Length of Juvenile Shorebirds: No Evidence of Developmental Temperatures Driving Morphological Changes},
  shorttitle = {Shape-shifting in Relative Wing Length of Juvenile Shorebirds},
  author = {Ryding, Sara and McQueen, Alexandra and Symonds, Matthew R.E. and Tattersall, Glenn J. and Wader Study Group, Victorian and Wader Studies Group, Australasian and Rogers, Danny I. and Atkinson, Robyn and Jessop, Roz and Hassell, Chris J. and Christie, Maureen and Ross, Tobias A. and Klaassen, Marcel},
  year = 2025,
  month = sep,
  journal = {Ecography},
  volume = {2025},
  number = {9},
  pages = {e07801},
  issn = {0906-7590, 1600-0587},
  doi = {10.1002/ecog.07801},
  urldate = {2025-09-27},
  abstract = {Morphological changes concurrent with climate change are increasingly identified in birds, often through decreasing body size and increasing appendage size. Such changes could have thermoregulatory implications, through the improved surface area to body ratio they provide. Due to the role of bird wings in thermoregulation, wing length relative to body mass may be changing as another form of shape-shifting, where increased relative wing length may facilitate increased heat loss as climates warm. We investigated changes in relative wing length on a dataset of nearly 20 000 juvenile shorebirds from 11 species over the past four decades, to determine changes in morphology and whether these are linked to developmental temperatures. Overall, across species, we found that relative wing length increased across the 43-year study period in populations migrating to tropical northern Australia but not in those migrating to temperate southern Australia. Furthermore, we found that changes in relative wing length were not driven by immediate responses to high temperature at the breeding ground during juvenile growth. These results may suggest that relative wing length increases occur in shorebirds occupying already warm climates, where they might potentially be more thermally challenged under further warming, but that such changes are not occurring through plastic mechanisms during development.},
  langid = {english},
  file = {/Users/aaronskinner/Desktop/Grad_School/Zotero/storage/GMCCKY3V/ecog13329-sup-0001-appendixs1.docx;/Users/aaronskinner/Desktop/Grad_School/Zotero/storage/H2H629R5/Ryding et al. - 2025 - Shape‐shifting in relative wing length of juvenile shorebirds no evidence of developmental temperat.pdf}
}

